# 惟元門市系統 - 環境變數範例
# 複製此檔案為 .env 並填入實際值

# Supabase 設定
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# 安全性設定
# 警告：不要在前端硬編碼密碼！
# 建議實作後端 API 進行身份驗證
AUTH_BACKEND_URL=https://your-api.com/auth

# 應用設定
APP_VERSION=4.7
APP_ENV=production

# 重要安全提醒：
# 1. 永不將 .env 檔案提交到版本控制
# 2. 使用 Supabase RLS (Row Level Security) 保護資料
# 3. 實作後端 API 進行密碼驗證
# 4. 定期輪換 API 金鑰
