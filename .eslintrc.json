{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "globals": {
    "orders": "writable",
    "supabaseReady": "writable",
    "HISTORY": "readonly",
    "SUPABASE_URL": "readonly",
    "SUPABASE_ANON_KEY": "readonly",
    "VENDOR_CATEGORIES": "readonly",
    "VENDOR_ORDER": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-undef": "error",
    "prefer-const": "warn",
    "no-var": "warn"
  }
}
